    {
      "id": 1,
      "prompt": "I need to build a Flink scalar UDF in Java that converts email addresses to their domain names. I want to deploy this to Confluent Cloud and use it from Flink SQL. Can you help me create the function, build it, and deploy it?",
      "expected_output": "Creates a Java scalar UDF that extracts domain from email, provides Maven/Gradle build configuration, generates the JAR, uploads it to Confluent Cloud as an artifact, and shows how to register and invoke the function in Flink SQL.",
      "files": [],
      "assertions": [
        {
          "id": "pom-exists",
          "type": "file_exists",
          "description": "pom.xml is generated for Maven build",
          "path": "pom.xml"
        },
        {
          "id": "pom-has-flink-table-api",
          "type": "file_contains",
          "description": "pom.xml depends on flink-table-api-java",
          "path": "pom.xml",
          "contains": "flink-table-api-java"
        },
        {
          "id": "pom-has-provided-scope",
          "type": "file_contains",
          "description": "Flink dependencies are marked as 'provided'",
          "path": "pom.xml",
          "contains": "provided"
        },
        {
          "id": "udf-extends-scalar-function",
          "type": "command",
          "description": "Java source contains a class extending ScalarFunction",
          "command": "grep -r 'extends ScalarFunction' {{output_dir}}/src/main/java 2>&1",
          "expect_exit_code": 0
        },
        {
          "id": "udf-has-eval-method",
          "type": "command",
          "description": "Java source contains an eval() method",
          "command": "grep -rE 'public[[:space:]]+[A-Za-z<>]+[[:space:]]+eval[[:space:]]*\\(' {{output_dir}}/src/main/java 2>&1",
          "expect_exit_code": 0
